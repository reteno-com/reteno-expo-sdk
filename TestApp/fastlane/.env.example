# Copy to `.env` and fill in real values. `.env` is gitignored.
# `.env` is auto-loaded by Fastlane from this directory.

# === App Store Connect API Key ===
# Option A: local .p8 file (gitignored, place next to this file)
APP_STORE_CONNECT_API_KEY_PATH=./AuthKey.p8
# Option B: private git repo containing the .p8 (used when local file is absent)
# APP_STORE_CONNECT_API_KEY_GIT_REPO_URL=git@github.com:your-org/your-certs-repo.git
# APP_STORE_CONNECT_API_KEY_GIT_REPO_BRANCH=main

# Generate key at https://appstoreconnect.apple.com/access/api
APP_STORE_CONNECT_API_KEY_KEY_ID=
APP_STORE_CONNECT_API_KEY_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_IN_HOUSE=false

# === Apple Developer team ===
# Find at https://developer.apple.com/account (Membership)
FASTLANE_TEAM_ID=
# MATCH_USERNAME=your-apple-id@example.com

# === Bundle id ===
# Must be registered in Apple Developer Portal AND match the value in
# `testapp.xcodeproj` (PRODUCT_BUNDLE_IDENTIFIER). Comma-separated if multiple.
MATCH_APP_IDENTIFIER=com.your-org.expo-example

# === Match (signing repo) ===
# A separate private git repo where match stores encrypted certs/profiles.
MATCH_GIT_URL=git@github.com:your-org/your-certificates-repo.git
MATCH_GIT_BRANCH=expo-example
MATCH_PASSWORD=
# MATCH_FORCE_LEGACY_ENCRYPTION=true

# === Xcode build ===
GYM_WORKSPACE=ios/testapp.xcworkspace
XC_PROJECT=ios/testapp.xcodeproj
GYM_SCHEME=testapp
GYM_CONFIGURATION=Release
CI_OUTPUT_DIRECTORY=./build
