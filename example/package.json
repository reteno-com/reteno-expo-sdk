{
  "name": "expo-reteno-sdk-example",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "purge": "rm -Rf node_modules package-lock.json ios android",
    "restart:ios": "npm run purge && npm install && npx expo prebuild -p ios --clean && npx pod-install && npm run ios"
  },
  "dependencies": {
    "expo": "~54.0.31",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "expo-reteno-sdk": "file:.."
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "nativeModulesDir": ".."
    }
  }
}
